# Backend to use: groq | gemini | ollama
LLM_BACKEND=groq

# Groq (primary)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional global/API RPM cap
LLM_MAX_RPM=8

# Gemini (optional fallback backend)
GEMINI_API_KEY=

# Ollama (optional fallback backend)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
